{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/main.{ts,tsx,js,jsx}",
    "src/pages/**/*.{astro,ts}"
  ],
  "duplicates": {
    "minOccurrences": 3
  },
  "rules": {
    "unused-dependencies": "warn"
  },
  "health": {
    "maxCyclomatic": 15,
    "maxCognitive": 22,
    "maxCrap": 38.0
  },
  "ignoreUnresolvedImports": [
    "../utils/HeightMap",
    "../utils/TextureGenerator",
    "../../utils/CyberpunkAudio",
    "../../utils/AudioManager",
    "../../utils/HeightMap",
    "**/ssr-app.js"
  ],
  "ignorePatterns": [
    "**/tests/setupHead.ts",
    "**/tests/setupThree.ts"
  ]
}
