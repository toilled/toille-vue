{
  "name": "toille-vue",
  "version": "2.0.0",
  "description": "A test website for Elliot Dickerson",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:server && node scripts/generate.mjs",
    "build:client": "vite build --outDir dist",
    "build:server": "vite build --config vite.config.ssr.ts --ssr && find functions -maxdepth 1 -type f \\( -name '*.png' -o -name '*.svg' -o -name '*.ico' -o -name '*.xml' -o -name '*.txt' -o -name '*.webmanifest' -o -name '_headers' \\) -delete",
    "build:ssg": "npm run build:client && npm run build:server && node scripts/generate.mjs",
    "preview": "vite preview",
    "pages:dev": "mv wrangler.toml wrangler.toml.bak && wrangler pages dev --d1 DB=toille-vue-db -- npm run dev; mv wrangler.toml.bak wrangler.toml",
    "db:init": "wrangler d1 execute toille-vue-db --local --file=./schema.sql",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "test:a11y": "vitest run --testPathPattern='a11y' && playwright test e2e/a11y.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.61.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^15.15.0",
    "jsdom": "^27.0.0",
    "prettier": "3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.4.1",
    "vite-plugin-bundler": "^0.1.5",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^3.3.3",
    "wrangler": "^4.54.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@unhead/vue": "^3.1.5",
    "@vue/server-renderer": "^3.5.27",
    "mqtt": "^5.15.1",
    "pinia": "^4.0.2",
    "sanitize-html": "^2.17.6",
    "three": "^0.181.2",
    "vue": "^3.4.31",
    "vue-i18n": "^11.4.5",
    "vue-router": "^4.4.0"
  }
}
