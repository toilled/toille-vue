{
  "name": "toille-vue",
  "version": "2.0.0",
  "description": "A test website for Elliot Dickerson",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/fix-wrangler-json.mjs",
    "preview": "astro build && wrangler pages dev dist",
    "pages:dev": "astro dev",
    "db:init": "wrangler d1 execute toille-vue-db --local --file=./schema.sql",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "license": "MIT",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.21.0",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^15.15.0",
    "jsdom": "^27.0.0",
    "prettier": "3.5.3",
    "terser": "^5.44.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.3.3",
    "wrangler": "^4.54.0"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@astrojs/vue": "^7.0.1",
    "@unhead/vue": "^3.1.7",
    "astro": "^7.0.6",
    "dompurify": "^3.4.1",
    "mqtt": "^5.15.1",
    "three": "^0.181.2",
    "vue": "^3.4.31",
    "vue-i18n": "^11.4.5",
    "vue-router": "^4.4.0"
  }
}
