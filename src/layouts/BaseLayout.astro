---
import AppShell from "../components/AppShell.vue";
import CyberpunkCity from "../components/CyberpunkCity.vue";
import "../assets/main.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="The experimental website of Elliot Dickerson." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Elliot Dickerson</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <AppShell client:idle />

    <main id="main-content" tabindex="-1" class="app-main">
      <div class="container">
        <slot />
      </div>
    </main>

    <CyberpunkCity client:visible />
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    top: 0;
    left: 0;
    transform: translateY(-100%);
    background: var(--primary, #1095c1);
    color: white;
    padding: 8px 16px;
    z-index: 100;
    text-decoration: none;
    transition: transform 0.1s ease;
    border-radius: 0 0 4px 0;
  }
  .skip-link:focus {
    transform: translateY(0);
  }
  .app-main {
    padding: 2rem 0;
    min-height: 60vh;
  }
  @media (max-width: 768px) {
    .app-main {
      padding: 1rem 0;
    }
  }
  #main-content:focus {
    outline: none;
  }
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 80px;
  }
  @media (max-width: 768px) {
    html {
      scroll-padding-top: 180px;
    }
  }
</style>
